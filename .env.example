# API
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=O2IAS_CMS
MYSQL_USER=oxygen_cms
MYSQL_PASSWORD=oxygen_cms_dev_password

# Required before storing remote OxyGen instance credentials.
# Generate with: openssl rand -base64 32
OXYGEN_CMS_ENCRYPTION_KEY=

# Phase 1.5 BullMQ / Redis queue foundation.
# Leave disabled for MVP poller mode; set BULLMQ_ENABLED=true once Redis is deployed.
BULLMQ_ENABLED=false
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
BULL_BOARD_ENABLED=false
BULL_BOARD_PATH=/admin/queues

# Milestone 7D guarded update runner. Disabled by default; enable only for self-hosted deployments where the API may spawn the host update script.
CMS_UPDATE_RUNNER_ENABLED=false
CMS_UPDATE_RUNNER_COMMAND=scripts/deploy.sh
CMS_UPDATE_RUNNER_CWD=
CMS_UPDATE_CONFIRMATION_VARIABLE=CONFIRM_UPDATE
CMS_UPDATE_TARGET_REF=
