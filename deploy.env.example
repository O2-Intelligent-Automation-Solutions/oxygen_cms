# OxyGen CMS production/self-contained Docker deployment template.
# Copy to deploy/.env or run: scripts/deploy.sh init
# Do not commit deploy/.env.

COMPOSE_PROJECT_NAME=oxygen-cms
CMS_IMAGE=oxygen-cms:local
CMS_HTTP_PORT=8080
# Optional: public URL shown in docs/update flows; HTTPS is typically terminated by a reverse proxy in front of this HTTP port.
CMS_PUBLIC_URL=http://localhost:8080
CMS_APP_CONTAINER_NAME=oxygen-cms-prod-app
CMS_MYSQL_CONTAINER_NAME=oxygen-cms-prod-mysql
CMS_REDIS_CONTAINER_NAME=oxygen-cms-prod-redis
CMS_WORKER_CONTAINER_NAME=oxygen-cms-prod-worker

# BullMQ/Redis worker orchestration is opt-in. `scripts/deploy.sh start-workers`
# starts the app and worker profile with BULLMQ_ENABLED=true for worker deployments.
BULLMQ_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
BULL_BOARD_ENABLED=false
BULL_BOARD_PATH=/admin/queues

MYSQL_DATABASE=O2IAS_CMS
MYSQL_USER=oxygen_cms
MYSQL_PASSWORD=replace-with-generated-secret
MYSQL_ROOT_PASSWORD=replace-with-generated-secret

# Generate with: openssl rand -base64 32
OXYGEN_CMS_ENCRYPTION_KEY=replace-with-generated-secret

# Guarded in-place update runner. Leave disabled unless this deployment intentionally allows the CMS API to spawn the host update script.
CMS_UPDATE_RUNNER_ENABLED=false
CMS_UPDATE_RUNNER_COMMAND=scripts/deploy.sh
CMS_UPDATE_RUNNER_CWD=/workspace
CMS_UPDATE_CONFIRMATION_VARIABLE=CONFIRM_UPDATE
CMS_UPDATE_TARGET_REF=main

# Queued backup worker settings. Disabled by default; scripts/deploy.sh backup remains the guarded host-side backup path unless queued backup workers are explicitly enabled.
CMS_BACKUP_JOBS_ENABLED=false
CMS_BACKUP_DIR=deploy/backups
CMS_BACKUP_RETENTION_DAYS=30
CMS_BACKUP_MAX_ARTIFACTS=25
CMS_BACKUP_INCLUDE_APP_DATA=true
