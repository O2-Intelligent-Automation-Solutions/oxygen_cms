{
  "name": "oxygen-cms",
  "version": "0.1.0",
  "private": true,
  "description": "OxyGen Central Management Server",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:db:reset": "bash scripts/dev-db-reset.sh",
    "dev:managed": "bash scripts/dev-up-managed.sh",
    "dev:managed:smoke": "bash scripts/dev-managed-smoke.sh",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:mysql-auth": "MYSQL_INTEGRATION_TESTS=true npm --workspace @oxygen-cms/api test -- --run tests/mysqlAuthRepository.test.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@progress/kendo-data-query": "^1.7.4",
    "@progress/kendo-licensing": "^1.11.2",
    "@progress/kendo-react-buttons": "^15.0.0",
    "@progress/kendo-react-common": "^15.0.0",
    "@progress/kendo-react-data-tools": "^15.0.0",
    "@progress/kendo-react-dialogs": "^15.0.0",
    "@progress/kendo-react-grid": "^15.0.0",
    "@progress/kendo-react-inputs": "^15.0.0",
    "@progress/kendo-react-intl": "^15.0.0",
    "@progress/kendo-react-labels": "^15.0.0",
    "@progress/kendo-theme-default": "^14.1.0"
  }
}
