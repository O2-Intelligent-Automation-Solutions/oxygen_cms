{
  "name": "@oxygen-cms/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "start:worker": "node dist/src/worker.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bull-board/api": "^8.0.0",
    "@bull-board/fastify": "^8.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "bullmq": "^5.78.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "knex": "^3.1.0",
    "mysql2": "^3.15.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
